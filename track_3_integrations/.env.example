# ----------------------------------------------------------------------------
# Track 3 Integrations — environment configuration
# Copy to `.env` and fill in. Anything left blank => that integration runs in
# MOCK mode so the demo still works on stage without live credentials.
# ----------------------------------------------------------------------------

PORT=3003

# Force mock mode for everything regardless of keys (great for stage rehearsal).
# Set to "true" to never hit a real external API.
MOCK_MODE=false

# Default location used when Track 2 doesn't pass one.
DEFAULT_LOCATION=San Francisco, CA

# --- Serper.dev (contractor search via Google Places) ----------------------
SERPER_API_KEY=

# --- Twilio WhatsApp ---------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sandbox number (default sandbox shown below).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram (fallback channel) --------------------------------------------
TELEGRAM_BOT_TOKEN=
# Default chat id to deliver to if a contractor has no telegram id mapped.
TELEGRAM_DEFAULT_CHAT_ID=
