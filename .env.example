# InsForge browser/server configuration
INSFORGE_BASE_URL=https://pzv974n7.us-east.insforge.app
INSFORGE_ANON_KEY=

# Server-only InsForge admin key for trusted internal Edge Function work.
# Keep this out of browser bundles.
INSFORGE_API_KEY=

# Server-side model gateway key. Keep out of browser bundles.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Internal function dispatch secret generated with: openssl rand -hex 32
AGENT_INTERNAL_SECRET=

# Optional real contractor search. Empty value enables mock search.
SERPAPI_KEY=

# Optional WhatsApp messaging. Empty values enable mock notification records.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional Telegram messaging. When both values are present, contractor outreach
# is routed to this one Telegram chat for demo testing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
